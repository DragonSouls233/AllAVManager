# =============================================================================
# MDCX 高级档部署环境变量配置（docker-compose.advanced.yml 使用）
#
# 使用方法：
#   cp .env.example .env
#   vim .env  # 修改密码、域名等敏感信息
#   docker compose -f docker-compose.advanced.yml up -d
#
# 安全提示：
#   - 生产环境务必修改所有默认密码
#   - .env 文件不要提交到版本控制
#   - 定期轮换密码
# =============================================================================

# ---------- PostgreSQL 数据库 ----------
POSTGRES_DB=mdcx
POSTGRES_USER=mdcx
# 生产环境必须修改为强密码（至少 16 位，含大小写字母+数字+符号）
POSTGRES_PASSWORD=mdcx_change_me_in_production

# ---------- Redis 缓存 ----------
REDIS_PASSWORD=mdcx_redis_change_me

# ---------- MDCX 应用 ----------
MDCX_LOG_LEVEL=info
# 媒体库挂载目录（宿主机路径）
MEDIA_DIR=./media

# ---------- Nginx 反向代理 ----------
# 域名（用于 TLS 证书与 server_name）
MDCX_DOMAIN=mdcx.example.com

# ---------- 可选：外部 PostgreSQL/Redis（高级档自定义） ----------
# 若使用外部数据库，取消注释并修改
# MDCX_DB_HOST=192.168.1.100
# MDCX_DB_PORT=5432
# MDCX_DB_POOL_SIZE=20

# ---------- 可选：邮件/通知 ----------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=mdcx@example.com
# SMTP_PASSWORD=change_me
